# Vite环境变量必须顶格写，注释单独行，值无需加单引号（Vite会自动解析）
VITE_TITLE = 朱某的生活印记
# 后端API地址
VITE_API_URI = https://cs.zhuxu.asia
# API密钥（未开启则留空）
VITE_API_KEY = 
# 外部库脚本注入（按需填写，默认空）
VITE_LIBS = 
# 程序版本号
VITE_VERSION = 1.0.0
# 路由模式 history|hash
VITE_ROUTER_MODE = history
# Vite基础路径
VITE_BASE_URL = /
# Token存储的Cookie名称
VITE_TOKEN_NAME = INIS_LOGIN_TOKEN
# 通用交互延迟（毫秒）
VITE_LAZY_TIME = 500
VITE_AES_KEY=your_32byte_aes_key_here
VITE_AES_IV=your_16byte_iv_here
VITE_CRYPTO_SALT=your_salt_value